<Window x:Class="AvmController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anti-VM Countermeasure Controller"
        Height="820"
        Width="1400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="Driver Status" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="KernelStatusText" FontWeight="SemiBold" Text="Kernel: disconnected" />
                    <TextBlock x:Name="KernelMetricsText" Text="Targets: 0  Events: 0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="FilterStatusText" FontWeight="SemiBold" Text="Minifilter: disconnected" />
                    <TextBlock x:Name="FilterMetricsText" Text="Rules: 0  Events: 0" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="120" Margin="0,0,8,0" Content="Refresh" Click="RefreshButton_Click" />
                    <Button Width="160" Content="Apply Policy" Click="ApplyPolicyButton_Click" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Target Processes" Margin="0,0,12,0">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Add a process that should receive concealment. In Full Concealment mode, you usually do not need targets."
                                   TextWrapping="Wrap" Margin="0,0,0,8" />
                        <ComboBox x:Name="TargetKindCombo" SelectedIndex="0" Margin="0,0,0,8">
                            <ComboBoxItem Content="PID" />
                            <ComboBoxItem Content="Image Name" />
                            <ComboBoxItem Content="Image Path Prefix" />
                        </ComboBox>
                        <TextBox x:Name="TargetValueText" Margin="0,0,0,8"
                                 ToolTip="Enter the process to protect from seeing VM artifacts: a PID, image name like malware.exe, or a path prefix" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Width="140" Margin="0,0,8,0" Content="Add Target" Click="AddTargetButton_Click"
                                    ToolTip="Register a process that should receive concealment" />
                            <Button Width="140" Content="Inject Shim" Click="InjectShimButton_Click"
                                    ToolTip="Inject the shim DLL into a running process by PID" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Width="290" Content="Launch with Shim…" Click="LaunchWithShimButton_Click"
                                    ToolTip="Browse for an exe, launch it suspended, inject the shim, then resume" />
                        </StackPanel>
                    </StackPanel>
                    <ListBox x:Name="TargetsList" Margin="0,8,0,0" />
                </DockPanel>
            </GroupBox>

            <GroupBox Header="Modes and Checks" Grid.Column="1" Margin="0,0,12,0">
                <StackPanel Margin="8">
                    <ComboBox x:Name="ModeCombo" SelectedIndex="2" Margin="0,0,0,12">
                        <ComboBoxItem Content="Observe" />
                        <ComboBoxItem Content="Selective Concealment" />
                        <ComboBoxItem Content="Full Concealment" />
                    </ComboBox>
                    <CheckBox x:Name="DebuggerCheck" Content="Debugger concealment" IsChecked="True" />
                    <CheckBox x:Name="TimingCheck" Content="Timing normalization" IsChecked="True" />
                    <CheckBox x:Name="NativeApiCheck" Content="Native API monitoring" IsChecked="True" />
                    <CheckBox x:Name="ProcessEnumCheck" Content="Process/tool concealment" IsChecked="True" />
                    <CheckBox x:Name="DriverProbeCheck" Content="Driver/device probe filtering" IsChecked="True" />
                    <CheckBox x:Name="RegistryCheck" Content="Registry artifact hiding" IsChecked="True" />
                    <CheckBox x:Name="FileCheck" Content="File artifact hiding" IsChecked="True" />
                    <CheckBox x:Name="DirectoryCheck" Content="Directory listing filtering" IsChecked="True" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="File Rules" Grid.Column="2">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Path to hide:" FontSize="11" Foreground="Gray" Margin="0,0,0,2" />
                        <TextBox x:Name="MatchPathText" Margin="0,0,0,8" ToolTip="e.g. C:\Windows\System32\drivers\vmci.sys" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Width="120" Margin="0,0,8,0" Content="Add Hide Rule" Click="AddHideRuleButton_Click" ToolTip="Makes the file appear nonexistent" />
                            <Button Width="120" Margin="0,0,8,0" Content="Remove Selected" Click="RemoveRuleButton_Click" ToolTip="Remove the selected rule from the list" />
                            <Button Width="100" Content="Clear Rules" Click="ClearRulesButton_Click" ToolTip="Remove all custom file rules" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="120" Content="Export Logs" Click="ExportLogsButton_Click" />
                        </StackPanel>
                    </StackPanel>
                    <ListBox x:Name="RulesList" Margin="0,12,0,0" />
                </DockPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Telemetry">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Filter:" />
                    <TextBox x:Name="TelemetryFilterText" Width="280" Margin="0,0,8,0"
                             ToolTip="Filter by source, PID, process, original text, or spoofed text"
                             TextChanged="TelemetryFilterText_TextChanged" />
                    <Button Width="110" Margin="0,0,8,0" Content="Newest First" Click="SortTelemetryNewest_Click" />
                    <Button Width="110" Margin="0,0,8,0" Content="Oldest First" Click="SortTelemetryOldest_Click" />
                    <Button Width="90" Content="Clear" Click="ClearTelemetryButton_Click" />
                </StackPanel>
                <DataGrid x:Name="TelemetryGrid" AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Telemetry}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="160" />
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90" />
                    <DataGridTextColumn Header="Category" Binding="{Binding QueryCategory}" Width="110" />
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70" />
                    <DataGridTextColumn Header="Original" Binding="{Binding OriginalText}" Width="200" />
                    <DataGridTextColumn Header="Spoofed" Binding="{Binding SpoofedText}" Width="200" />
                    <DataGridTextColumn Header="Process" Binding="{Binding ImagePath}" Width="*" />
                </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
